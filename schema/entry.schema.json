{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/osick/lemmatize/schema/entry.schema.json",
  "title": "Lemmatize theorem entry",
  "description": "Schema for a single per-theorem YAML file under lemmatize/. See docs/requirements.md §R2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "wikidata",
    "canonical_name",
    "short_form",
    "mathlib_declaration",
    "mathlib_file",
    "mathlib_lines",
    "mathlib_commit_verified_against",
    "mathlib_statement",
    "mathlib_proof_body",
    "proof_method_lean",
    "proof_method_textbook",
    "dependencies",
    "verbalization",
    "verification"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable kebab-case identifier matching the filename without .yaml"
    },
    "wikidata": {
      "type": "string",
      "pattern": "^(Q[0-9]+|TBD)$"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "canonical_name": {
      "type": "object",
      "required": ["en"],
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "short_form": {
      "type": "object",
      "required": ["en"],
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "mathlib_declaration": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.']*$"
    },
    "mathlib_file": {
      "type": "string",
      "pattern": "^Mathlib(/[A-Za-z0-9_.-]+)+\\.lean$"
    },
    "mathlib_lines": {
      "type": "string",
      "pattern": "^[0-9]+-[0-9]+$"
    },
    "mathlib_commit_verified_against": {
      "type": "string",
      "pattern": "^([0-9a-f]{40}|TBD)$"
    },
    "mathlib_statement": { "type": "string", "minLength": 1 },
    "mathlib_proof_body": { "type": "string", "minLength": 1 },
    "proof_method_lean": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "proof_method_textbook": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "essential_hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "technical_hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["declaration", "canonical_name", "gloss"],
        "properties": {
          "declaration": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_.']*$" },
          "canonical_name": { "type": "string", "minLength": 1 },
          "gloss": { "type": "string", "minLength": 1 },
          "lemmatize_id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
        }
      }
    },
    "proof_chain": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verbalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["researcher", "faithful_to_mathlib", "textbook_classical"],
      "properties": {
        "researcher": { "type": "string", "minLength": 1 },
        "faithful_to_mathlib": { "type": "string", "minLength": 1 },
        "textbook_classical": { "type": "string", "minLength": 1 }
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "source", "checked_on"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "checked_on": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "checker": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
